generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Restaurant
// ---------------------------------------------------------------------------
model Restaurant {
  id                      String   @id @default(uuid())
  slug                    String?  @unique
  name                    String
  description             String?
  address                 String?
  city                    String?
  postalCode              String?
  country                 String?  @default("FR")
  phone                   String?
  email                   String?
  website                 String?
  logoId                  String?  @unique
  logo                    Media?   @relation("RestaurantLogo", fields: [logoId], references: [id])
  coverImageId            String?  @unique
  coverImage              Media?   @relation("RestaurantCoverImage", fields: [coverImageId], references: [id])
  acceptReservations      Boolean  @default(false)
  depositPerGuestCents    Int      @default(0)
  avgPrepMinutes          Int      @default(90)
  reservationLeadMinutes  Int      @default(60)
  reservationSlotMinutes  Int      @default(30)
  reservationPolicy       String?
  tipsEnabled             Boolean  @default(true)
  serviceCallEnabled      Boolean  @default(true)
  reviewsEnabled          Boolean  @default(true)
   
  // NovaTech IA Subscription
  subscription            SubscriptionPlan @default(STARTER)
  ollamaApiKey            String?
  ollamaLangModel         String?  @default("gpt-oss:120b")
  ollamaVisionModel       String?  @default("llama3.2-vision:11b")
  subscriptionStartedAt   DateTime?
  subscriptionExpiresAt   DateTime?
   
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt
 
  users          User[]
  tables         Table[]
  menuItems      MenuItem[]
  servers        Server[]
  openingHours   OpeningHour[]
  reservations   Reservation[]
  serviceCalls   ServiceCall[]
  dishReviews    DishReview[]
  serverReviews  ServerReview[]
  stockMovements StockMovement[]
  media          Media[]
  photos         Photo[] @relation("RestaurantPhotos")
  testimonial    Testimonial?
  socialProfiles SocialProfile[] // Active profiles in this restaurant
 
  @@index([slug])
}

model Photo {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation("RestaurantPhotos", fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItemId   String?
  menuItem     MenuItem?  @relation("MenuItemPhotos", fields: [menuItemId], references: [id], onDelete: Cascade)
  kind         String     @default("RESTAURANT") // RESTAURANT | DISH
  mimeType     String
  bytes        Bytes
  size         Int
  originalName String?
  sha256       String?
  position     Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, kind])
  @@index([menuItemId])
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------
model User {
  id           String      @id @default(uuid())
  email        String?     @unique
  passwordHash String?     // nullable: shared DB with RSMATABLE (social users have no passwordHash)
  // --- shadow columns owned by RSMATABLE / MaTableAdmin (do NOT remove) ---
  name          String?
  emailVerified DateTime?
  image         String?
  password      String?
  // ------------------------------------------------------------------------
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String?     // nullable: social users are not tied to a restaurant
  createdAt    DateTime?   @default(now())

  @@index([restaurantId])
}

// ---------------------------------------------------------------------------
// Tables & sessions
// ---------------------------------------------------------------------------
model Table {
  id               String         @id @default(uuid())
  number           Int
  seats            Int            @default(2)
  label            String?
  zone             String?        // "Salle principale", "Terrasse", "Mezzanine", "VIP"…
  assignedServerId String?
  assignedServer   Server?        @relation("TableAssignedServer", fields: [assignedServerId], references: [id], onDelete: SetNull)
  restaurant       Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId     String
  sessions         TableSession[]
  orders           Order[]
  reservations     Reservation[]
  serviceCalls     ServiceCall[]
  createdAt        DateTime       @default(now())

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@index([restaurantId, zone])
}

model TableSession {
  id              String       @id @default(uuid())
  table           Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId         String
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  closedAt        DateTime?
  billRequestedAt DateTime?
  billPaymentMode PaymentMode?
  tipCents        Int          @default(0)
  serverId        String?
  server          Server?      @relation(fields: [serverId], references: [id], onDelete: SetNull)
  orders          Order[]
  serviceCalls    ServiceCall[]
  socialProfileId String?      // Link to social profile if active
  socialProfile   SocialProfile? @relation(fields: [socialProfileId], references: [id], onDelete: SetNull)

  @@index([tableId, active])
  @@index([serverId])
  @@index([socialProfileId])
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------
model Order {
  id         String       @id @default(uuid())
  table      Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId    String
  session    TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId  String
  server     Server?      @relation(fields: [serverId], references: [id], onDelete: SetNull)
  serverId   String?
  status     OrderStatus  @default(PENDING)
  items      Json
  totalCents Int
  tipCents   Int          @default(0)
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  dishReviews   DishReview[]
  serverReviews ServerReview[]

  @@index([tableId])
  @@index([status, createdAt])
  @@index([sessionId])
  @@index([serverId])
}

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------
model MenuItem {
  id                String    @id @default(uuid())
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId      String
  name              String
  description       String?
  priceCents        Int
  imageUrl          String?
  available         Boolean   @default(true)
  category          String?
  position          Int       @default(0)
  stockEnabled      Boolean   @default(false)
  stockQty          Int?
  lowStockThreshold Int?      @default(5)
  allergens         Allergen[] @default([])
  diets             Diet[]     @default([])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  modifierGroups ModifierGroup[]
  dishReviews    DishReview[]
  stockMovements StockMovement[]
  photos         Photo[] @relation("MenuItemPhotos")

  @@index([restaurantId])
  @@index([restaurantId, category])
}

model ModifierGroup {
  id         String           @id @default(uuid())
  menuItem   MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId String
  name       String
  required   Boolean          @default(false)
  multiple   Boolean          @default(false)
  position   Int              @default(0)
  options    ModifierOption[]

  @@index([menuItemId])
}

model ModifierOption {
  id             String        @id @default(uuid())
  group          ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId        String
  name           String
  priceDeltaCents Int          @default(0)
  position       Int           @default(0)
  available      Boolean       @default(true)

  @@index([groupId])
}

// ---------------------------------------------------------------------------
// Staff (serveurs)
// ---------------------------------------------------------------------------
model Server {
  id           String     @id @default(uuid())
  name         String
  photoUrl     String?
  active       Boolean    @default(true)
  pin          String?    // 4-digit PIN for server portal login
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  schedules    ServerSchedule[]
  sessions     TableSession[]
  orders       Order[]
  reviews      ServerReview[]
  notes        ServerNote[]
  challenges   ServerChallenge[]
  assignedTables Table[]          @relation("TableAssignedServer")
  createdAt    DateTime   @default(now())

  @@index([restaurantId, active])
}

model ServerNote {
  id        String   @id @default(uuid())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serverId])
}

model ServerChallenge {
  id           String   @id @default(uuid())
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId     String
  title        String
  done         Boolean  @default(false)
  dueDate      DateTime?
  isGlobal     Boolean  @default(false)  // true = AI-generated restaurant-wide daily challenge
  restaurantId String?                   // set for global challenges
  createdAt    DateTime @default(now())

  @@index([serverId])
  @@index([restaurantId, isGlobal, dueDate])
}

model ServerSchedule {
  id        String   @id @default(uuid())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId  String
  dayOfWeek Int
  openMin   Int
  closeMin  Int

  @@index([serverId])
}

// ---------------------------------------------------------------------------
// Opening hours
// ---------------------------------------------------------------------------
model OpeningHour {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  dayOfWeek    Int
  openMin      Int
  closeMin     Int
  service      String?

  @@index([restaurantId, dayOfWeek])
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------
model DishReview {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId   String
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId      String?
  rating       Int
  comment      String?
  verified     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
}

model ServerReview {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  server       Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId     String
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId      String?
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())

  @@index([serverId, createdAt])
  @@index([restaurantId, createdAt])
}

// ---------------------------------------------------------------------------
// Service calls & stock movements
// ---------------------------------------------------------------------------
model ServiceCall {
  id           String        @id @default(uuid())
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  table        Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId      String
  session      TableSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionId    String?
  reason       String?
  createdAt    DateTime      @default(now())
  resolvedAt   DateTime?

  @@index([restaurantId, resolvedAt])
  @@index([tableId, resolvedAt])
}

model StockMovement {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId   String
  delta        Int
  reason       String
  orderId      String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
}

// ---------------------------------------------------------------------------
// Reservations
// ---------------------------------------------------------------------------
model Reservation {
  id              String     @id @default(uuid())
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId    String
  table           Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableId         String?
  startsAt        DateTime
  durationMin     Int        @default(90)
  partySize       Int
  customerName    String
  customerEmail   String
  customerPhone   String?
  notes           String?
  status          String     @default("PENDING")
  depositCents    Int        @default(0)
  depositStatus   String     @default("NONE")
  stripeSessionId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  cancelledAt     DateTime?

  @@index([restaurantId, startsAt])
  @@index([status, startsAt])
}

// ---------------------------------------------------------------------------
// Media (images stockées en Postgres Bytes)
// ---------------------------------------------------------------------------
model Media {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  mimeType     String
  bytes        Bytes
  size         Int
  originalName String?
  sha256       String?
  createdAt    DateTime   @default(now())

  // Inverse relations for Restaurant.logo / Restaurant.coverImage
  logoOfRestaurant       Restaurant? @relation("RestaurantLogo")
  coverImageOfRestaurant Restaurant? @relation("RestaurantCoverImage")

  @@index([restaurantId])
}

// ---------------------------------------------------------------------------
// Testimonial (témoignage vitrine publique)
// ---------------------------------------------------------------------------
model Testimonial {
  id           String     @id @default(uuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String     @unique
  displayName  String
  displayRole  String?
  quote        String
  rating       Int        @default(5)
  published    Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([published, updatedAt])
}

// ─── SOCIAL CORE (Nova Connect) ──────────────────────────────────────────────

enum SocialMode {
  BUSINESS
  FUN
  DATE
  HIDDEN
}

model SocialProfile {
  id           String      @id @default(uuid())
  // Can be linked to a permanent user (NextAuth user)
  externalId   String?     @unique // e.g. Google ID or NextAuth User ID
  name         String
  image        String?
  email        String?
  
  bio          String?     @db.Text
  interests    String[]    // Keywords for IA matching
  occupation   String?
  
  activeMode   SocialMode  @default(HIDDEN)
  onboardingData Json?     
  
  // Presence
  currentRestaurantId String?
  restaurant          Restaurant? @relation(fields: [currentRestaurantId], references: [id], onDelete: SetNull)
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt

  // Relations
  tableSessions TableSession[]
  sentPings     SocialPing[] @relation("SentPings")
  receivedPings SocialPing[] @relation("ReceivedPings")

  @@index([currentRestaurantId, activeMode])
}

model SocialPing {
  id          String   @id @default(uuid())
  senderId    String
  sender      SocialProfile @relation("SentPings", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    SocialProfile @relation("ReceivedPings", fields: [receiverId], references: [id], onDelete: Cascade)
  
  message     String?
  mode        SocialMode
  status      PingStatus @default(SENT)
  
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

enum PingStatus {
  SENT
  ACCEPTED
  DECLINED
  SEEN
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
enum OrderStatus {
  PENDING
  COOKING
  SERVED
  PAID
  CANCELLED
}

enum PaymentMode {
  CARD
  CASH
  COUNTER
}

enum Allergen {
  GLUTEN
  CRUSTACEANS
  EGGS
  FISH
  PEANUTS
  SOYBEANS
  MILK
  NUTS
  CELERY
  MUSTARD
  SESAME
  SULPHITES
  LUPIN
  MOLLUSCS
}

enum Diet {
  VEGETARIAN
  VEGAN
  GLUTEN_FREE
  LACTOSE_FREE
  HALAL
  KOSHER
  PORK_FREE
  LOW_CAL
  SPICY
}

enum SubscriptionPlan {
  STARTER
  PRO
  PRO_IA
}

// ---------------------------------------------------------------------------
// Prospection CRM
// ---------------------------------------------------------------------------
model Prospect {
  id           String    @id @default(uuid())
  name         String
  city         String?
  address      String?
  phone        String?
  email        String?
  description  String?   @db.Text
  website      String?
  category     String?
  imageUrl     String?
  sourceUrl    String?
  status       String    @default("NEW") // NEW | CONTACTED | ACTIVATED | IGNORED
  restaurantId String?
  notes        String?
  activatedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([status])
  @@index([city])
}
