# Base de données PostgreSQL (Railway fournit cette URL automatiquement)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/railway

# Clé secrète JWT — min 32 caractères, ne jamais partager
JWT_SECRET=change-moi-par-une-longue-chaine-aleatoire-ici

# URL publique du service web (ex: https://matable-production.up.railway.app)
PUBLIC_WEB_URL=https://TON-SERVICE-WEB.up.railway.app

# Port d'écoute de l'API (Railway injecte PORT automatiquement)
API_PORT=3001

# Environnement
NODE_ENV=production

# Stripe — optionnel, nécessaire pour le paiement en ligne
STRIPE_SECRET=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cloudinary — optionnel, nécessaire pour l'upload d'images depuis le dashboard
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx
